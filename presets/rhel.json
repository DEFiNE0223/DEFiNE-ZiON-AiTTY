{
  "id": "rhel", "name": "RHEL / CentOS / Rocky", "icon": "🔴", "color": "#CC0000",
  "pkg": "yum",
  "categories": [
    { "label": "📦 Packages", "commands": [
      { "label": "Update",              "cmd": "sudo yum update -y" },
      { "label": "Search package",      "cmd": "yum search " },
      { "label": "Install",             "cmd": "sudo yum install -y " },
      { "label": "Remove",              "cmd": "sudo yum remove " },
      { "label": "Installed list",      "cmd": "rpm -qa | sort" }
    ]},
    { "label": "🌐 Network", "commands": [
      { "label": "Show IP",             "cmd": "ip addr show" },
      { "label": "Listening ports",     "cmd": "ss -tulpn" },
      { "label": "Firewall status",     "cmd": "sudo firewall-cmd --list-all" },
      { "label": "Open firewall port",  "cmd": "sudo firewall-cmd --permanent --add-port=/tcp && sudo firewall-cmd --reload" },
      { "label": "Check iptables",      "cmd": "sudo iptables -L -n -v" }
    ]},
    { "label": "⚙️ System", "commands": [
      { "label": "OS info",             "cmd": "cat /etc/redhat-release && uname -r" },
      { "label": "Disk usage",          "cmd": "df -h" },
      { "label": "Memory",              "cmd": "free -h" },
      { "label": "SELinux status",      "cmd": "sestatus" },
      { "label": "Uptime",              "cmd": "uptime" }
    ]},
    { "label": "🔧 Services", "commands": [
      { "label": "Service list",        "cmd": "systemctl list-units --type=service --state=running" },
      { "label": "Service status",      "cmd": "systemctl status " },
      { "label": "Restart service",     "cmd": "sudo systemctl restart " },
      { "label": "Live logs",           "cmd": "sudo journalctl -fu " }
    ]},
    { "label": "🔐 Security", "commands": [
      { "label": "Login history",       "cmd": "last -20" },
      { "label": "Failed logins",       "cmd": "sudo grep 'Failed password' /var/log/secure | tail -20" },
      { "label": "SELinux deny log",    "cmd": "sudo ausearch -m avc -ts recent" }
    ]}
  ]
}
