{
  "id": "alpine", "name": "Alpine Linux", "icon": "🏔️", "color": "#0D597F",
  "pkg": "apk",
  "categories": [
    { "label": "📦 Packages", "commands": [
      { "label": "Update",              "cmd": "sudo apk update && apk upgrade" },
      { "label": "Search package",      "cmd": "apk search " },
      { "label": "Install",             "cmd": "sudo apk add " },
      { "label": "Remove",              "cmd": "sudo apk del " },
      { "label": "Installed list",      "cmd": "apk list --installed" }
    ]},
    { "label": "🌐 Network", "commands": [
      { "label": "Show IP",             "cmd": "ip addr show" },
      { "label": "Listening ports",     "cmd": "ss -tulpn" },
      { "label": "Firewall status",     "cmd": "sudo iptables -L -n" },
      { "label": "DNS info",            "cmd": "cat /etc/resolv.conf" }
    ]},
    { "label": "⚙️ System", "commands": [
      { "label": "OS info",             "cmd": "cat /etc/alpine-release && uname -r" },
      { "label": "Disk usage",          "cmd": "df -h" },
      { "label": "Memory",              "cmd": "free -m" },
      { "label": "Processes",           "cmd": "top" }
    ]},
    { "label": "🔧 Services (OpenRC)", "commands": [
      { "label": "Service list",        "cmd": "rc-status" },
      { "label": "Start service",       "cmd": "sudo rc-service  start" },
      { "label": "Stop service",        "cmd": "sudo rc-service  stop" },
      { "label": "Enable on boot",      "cmd": "sudo rc-update add " }
    ]}
  ]
}
