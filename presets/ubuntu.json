{
  "id": "ubuntu", "name": "Ubuntu / Debian", "icon": "🐧", "color": "#E95420",
  "pkg": "apt",
  "categories": [
    { "label": "📦 Packages", "commands": [
      { "label": "Update",              "cmd": "sudo apt update && sudo apt upgrade -y" },
      { "label": "Search package",      "cmd": "apt search " },
      { "label": "Install",             "cmd": "sudo apt install -y " },
      { "label": "Remove",              "cmd": "sudo apt remove " },
      { "label": "Installed list",      "cmd": "dpkg --list | grep '^ii'" }
    ]},
    { "label": "🌐 Network", "commands": [
      { "label": "Show IP",             "cmd": "ip addr show" },
      { "label": "Routing table",       "cmd": "ip route" },
      { "label": "Listening ports",     "cmd": "ss -tulpn" },
      { "label": "DNS info",            "cmd": "resolvectl status" },
      { "label": "Firewall status",     "cmd": "sudo ufw status verbose" },
      { "label": "Open firewall port",  "cmd": "sudo ufw allow " },
      { "label": "Ping test",           "cmd": "ping -c 4 " },
      { "label": "traceroute",          "cmd": "traceroute " },
      { "label": "Network interfaces",  "cmd": "ip link show" },
      { "label": "Apply Netplan",       "cmd": "sudo netplan apply" }
    ]},
    { "label": "⚙️ System", "commands": [
      { "label": "OS info",             "cmd": "lsb_release -a && uname -r" },
      { "label": "CPU / Memory",        "cmd": "htop" },
      { "label": "Disk usage",          "cmd": "df -h" },
      { "label": "Directory size",      "cmd": "du -sh /* 2>/dev/null | sort -rh | head -20" },
      { "label": "Memory detail",       "cmd": "free -h && cat /proc/meminfo | head -20" },
      { "label": "Uptime",              "cmd": "uptime && who" },
      { "label": "Process list",        "cmd": "ps aux --sort=-%cpu | head -20" },
      { "label": "Reboot required?",    "cmd": "ls /var/run/reboot-required 2>/dev/null && echo 'REBOOT REQUIRED' || echo 'No reboot needed'" }
    ]},
    { "label": "🔧 Services", "commands": [
      { "label": "Service list",        "cmd": "systemctl list-units --type=service --state=running" },
      { "label": "Service status",      "cmd": "systemctl status " },
      { "label": "Start service",       "cmd": "sudo systemctl start " },
      { "label": "Stop service",        "cmd": "sudo systemctl stop " },
      { "label": "Restart service",     "cmd": "sudo systemctl restart " },
      { "label": "Enable on boot",      "cmd": "sudo systemctl enable " },
      { "label": "Live logs",           "cmd": "sudo journalctl -fu " }
    ]},
    { "label": "🔐 Security", "commands": [
      { "label": "Login history",       "cmd": "last -20" },
      { "label": "Failed logins",       "cmd": "sudo grep 'Failed password' /var/log/auth.log | tail -20" },
      { "label": "sudo history",        "cmd": "sudo grep 'sudo' /var/log/auth.log | tail -20" },
      { "label": "Open files",          "cmd": "sudo lsof -i" },
      { "label": "SSH keys",            "cmd": "cat ~/.ssh/authorized_keys" }
    ]}
  ]
}
