{
  "id": "ubuntu", "name": "Ubuntu / Debian", "icon": "🐧", "color": "#E95420",
  "pkg": "apt",
  "categories": [
    { "label": "📦 패키지", "commands": [
      { "label": "업데이트",         "cmd": "sudo apt update && sudo apt upgrade -y" },
      { "label": "패키지 검색",      "cmd": "apt search " },
      { "label": "설치",             "cmd": "sudo apt install -y " },
      { "label": "삭제",             "cmd": "sudo apt remove " },
      { "label": "설치 목록",        "cmd": "dpkg --list | grep '^ii'" }
    ]},
    { "label": "🌐 네트워크", "commands": [
      { "label": "IP 확인",          "cmd": "ip addr show" },
      { "label": "라우팅 테이블",    "cmd": "ip route" },
      { "label": "포트 청취 확인",   "cmd": "ss -tulpn" },
      { "label": "DNS 확인",         "cmd": "resolvectl status" },
      { "label": "방화벽 상태",      "cmd": "sudo ufw status verbose" },
      { "label": "방화벽 열기",      "cmd": "sudo ufw allow " },
      { "label": "ping 테스트",      "cmd": "ping -c 4 " },
      { "label": "traceroute",        "cmd": "traceroute " },
      { "label": "네트워크 인터페이스","cmd": "ip link show" },
      { "label": "Netplan 적용",     "cmd": "sudo netplan apply" }
    ]},
    { "label": "⚙️ 시스템", "commands": [
      { "label": "OS 정보",          "cmd": "lsb_release -a && uname -r" },
      { "label": "CPU / 메모리",     "cmd": "htop" },
      { "label": "디스크 사용량",    "cmd": "df -h" },
      { "label": "디렉토리 용량",    "cmd": "du -sh /* 2>/dev/null | sort -rh | head -20" },
      { "label": "메모리 상세",      "cmd": "free -h && cat /proc/meminfo | head -20" },
      { "label": "업타임",           "cmd": "uptime && who" },
      { "label": "프로세스 목록",    "cmd": "ps aux --sort=-%cpu | head -20" },
      { "label": "재시작 필요 여부", "cmd": "ls /var/run/reboot-required 2>/dev/null && echo 'REBOOT REQUIRED' || echo 'No reboot needed'" }
    ]},
    { "label": "🔧 서비스", "commands": [
      { "label": "서비스 목록",      "cmd": "systemctl list-units --type=service --state=running" },
      { "label": "서비스 상태",      "cmd": "systemctl status " },
      { "label": "서비스 시작",      "cmd": "sudo systemctl start " },
      { "label": "서비스 중지",      "cmd": "sudo systemctl stop " },
      { "label": "서비스 재시작",    "cmd": "sudo systemctl restart " },
      { "label": "부팅 시 활성화",   "cmd": "sudo systemctl enable " },
      { "label": "실시간 로그",      "cmd": "sudo journalctl -fu " }
    ]},
    { "label": "🔐 보안", "commands": [
      { "label": "로그인 기록",      "cmd": "last -20" },
      { "label": "실패한 로그인",    "cmd": "sudo grep 'Failed password' /var/log/auth.log | tail -20" },
      { "label": "sudo 기록",        "cmd": "sudo grep 'sudo' /var/log/auth.log | tail -20" },
      { "label": "열린 파일",        "cmd": "sudo lsof -i" },
      { "label": "SSH 키 확인",      "cmd": "cat ~/.ssh/authorized_keys" }
    ]}
  ]
}
