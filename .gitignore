# ── 런타임 데이터 (절대 커밋 금지) ─────────────────────────────────
data/
# data/ 안에는 암호화된 API 키, 세션 정보, 마스터 패스워드 파생 데이터가 있음

# ── 환경 변수 / 시크릿 ───────────────────────────────────────────────
.env
.env.*
.env.local
.env.production
*.secret
secrets.*
config.local.*

# ── SSH / SSL / 인증서 키 ────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
id_rsa
id_ed25519
id_ecdsa
*.pub
known_hosts

# ── 로그 파일 ────────────────────────────────────────────────────────
*.log
logs/
server.log
server-err.log
npm-debug.log*
yarn-debug.log*

# ── Node.js ──────────────────────────────────────────────────────────
node_modules/
.npm
.yarn
.pnp.*

# ── 백업 / 임시 파일 ─────────────────────────────────────────────────
*.bak
*.backup
*.orig
*.tmp
*.swp
*.swo
*~
.#*

# ── OS 생성 파일 ─────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── 에디터 설정 ──────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.sublime-workspace
.history/

# ── 빌드 / 배포 ──────────────────────────────────────────────────────
dist/
build/
.cache/
