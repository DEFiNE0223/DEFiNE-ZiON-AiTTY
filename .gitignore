# ── Runtime data (never commit) ──────────────────────────────────
data/
# data/ contains encrypted API keys, session info, and master password derived data

# ── Environment variables / secrets ──────────────────────────────
.env
.env.*
.env.local
.env.production
*.secret
secrets.*
config.local.*

# ── SSH / SSL / certificate keys ─────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
id_rsa
id_ed25519
id_ecdsa
*.pub
known_hosts

# ── Log files ─────────────────────────────────────────────────────
*.log
logs/
server.log
server-err.log
npm-debug.log*
yarn-debug.log*

# ── Node.js ──────────────────────────────────────────────────────
node_modules/
.npm
.yarn
.pnp.*

# ── Backup / temp files ───────────────────────────────────────────
*.bak
*.backup
*.orig
*.tmp
*.swp
*.swo
*~
.#*

# ── OS generated files ────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Editor settings ───────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.sublime-workspace
.history/

# ── Build / deploy ────────────────────────────────────────────────
dist/
build/
.cache/
